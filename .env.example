# Local secrets — copy to .env (gitignored) and fill in real values.
# Anything in `.agents/mcp.json` referenced as ${VAR} must appear here.

# ── AI agent API keys (only set if not using OAuth) ──────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_CLOUD_PROJECT=

# ── MCP server credentials ───────────────────────────────────
# Add ${VAR}-named entries from your .agents/mcp.json here.
